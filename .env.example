# Server
REST_PORT=3000

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/postgres"

# Redis
REDIS_URL="redis://localhost:6379"

# OIDC Authentication
OIDC_ISSUER="https://sso.koiosdigital.net/realms/fittime"
OIDC_AUDIENCE="account"
OIDC_JWKS_URI="https://sso.koiosdigital.net/realms/fittime/protocol/openid-connect/certs"

# Keycloak Admin Service Account (client credentials grant)
KEYCLOAK_ADMIN_CLIENT_ID="fittime-backend-admin"
KEYCLOAK_ADMIN_CLIENT_SECRET=""

R2_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
R2_ACCESS_KEY_ID="..."
R2_SECRET_ACCESS_KEY="..."
R2_BUCKET="fittime"
R2_PUBLIC_URL="https://assets.fittime.app"

# Mux Video
# Create an Access Token at https://dashboard.mux.com/settings/access-tokens
# Configure a webhook at https://dashboard.mux.com/settings/webhooks pointing to <api>/v1/mux/webhook
MUX_TOKEN_ID=""
MUX_TOKEN_SECRET=""
MUX_WEBHOOK_SIGNING_SECRET=""
# CORS origin allowed to PUT direct uploads (frontend origin). Use "*" only in dev.
MUX_UPLOAD_CORS_ORIGIN="https://fittime-teal.vercel.app"

# Development/Debug
NODE_ENV=development
