// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client"
  output     = "../src/generated/prisma"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id // OIDC subject (sub) claim
  email     String?
  name      String?
  firstName String?  @map("first_name")
  lastName  String?  @map("last_name")
  username  String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  profile UserProfile?

  memberships      OrganizationMember[]
  submittedReports Report[]             @relation("ReportSubmitter")
  receivedReports  Report[]             @relation("ReportedUser")
  messages         Message[]
  createdChats     Chat[]               @relation("ChatCreator")
  chatMemberships  Chat[]               @relation("ChatMembers")
  teamCaptainships Team[]               @relation("TeamCaptain")
  teamMemberships  Team[]               @relation("TeamMembers")
  teamInvitations  TeamInvitation[]

  sessions           Session[]
  notifications      Notification[]
  achievements       UserAchievement[]
  createdTournaments Tournament[]      @relation("TournamentCreator")
  tournaments        Tournament[]      @relation("TournamentParticipants")

  @@map("users")
}

model Session {
  id     String @id @default(cuid())
  userId String @map("user_id")

  ipAddress String? @map("ip_address")
  userAgent String? @map("user_agent")
  location  String?

  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model UserProfile {
  userId    String   @id @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio       String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  pictures             UserProfilePicture[]
  favoriteSports       Sport[]              @relation("UserFavoriteSports")
  featuredAchievements UserAchievement[]    @relation("FeaturedAchievements")

  @@map("user_profiles")
}

model Sport {
  id   String  @id @default(uuid()) @db.Uuid
  name String  @unique
  icon String?

  profiles    UserProfile[] @relation("UserFavoriteSports")
  tournaments Tournament[]
  teams       Team[]

  @@map("sports")
}

model UserProfilePicture {
  id      String      @id @default(cuid())
  userId  String      @map("user_id")
  profile UserProfile @relation(fields: [userId], references: [userId], onDelete: Cascade)

  url       String
  alt       String?
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("user_profile_pictures")
}

model Organization {
  id        String   @id @default(cuid())
  name      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members     OrganizationMember[]
  tournaments Tournament[]
  chats       Chat[]

  gyms Gym[]

  @@map("organizations")
}

enum OrganizationRole {
  MEMBER
  STAFF
  ADMIN
}

model OrganizationMember {
  id             String           @id @default(cuid())
  userId         String           @map("user_id")
  organizationId String           @map("organization_id")
  role           OrganizationRole @default(MEMBER)
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@map("organization_members")
}

enum StatusOnReport {
  PENDING
  REVIEWED
  RESOLVED
  DISMISSED
}

model Report {
  id           String         @id @default(cuid())
  reporter     User           @relation("ReportSubmitter", fields: [userId1], references: [id])
  userId1      String
  reportedUser User           @relation("ReportedUser", fields: [userId2], references: [id])
  userId2      String
  reason       String?
  status       StatusOnReport @default(PENDING)
  createdAt    DateTime       @default(now()) @map("created_at")
}

enum ChatType {
  DIRECT
  GROUP
  ANNOUNCEMENT
  TEAM
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  FILE
}

model Chat {
  id        String    @id @default(cuid())
  type      ChatType  @default(GROUP)
  name      String?
  creatorId String    @map("creator_id")
  creator   User      @relation("ChatCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  members   User[]    @relation("ChatMembers")
  messages  Message[]
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  // Announcement channels (US #42)
  organizationId String?            @map("organization_id")
  organization   Organization?      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  writeRoles     OrganizationRole[] @default([])

  // Team-to-team chats (US #44)
  team1Id String? @map("team1_id")
  team1   Team?   @relation("ChatTeam1", fields: [team1Id], references: [id], onDelete: Cascade)
  team2Id String? @map("team2_id")
  team2   Team?   @relation("ChatTeam2", fields: [team2Id], references: [id], onDelete: Cascade)

  @@unique([team1Id, team2Id])
  @@index([creatorId])
  @@index([organizationId])
  @@map("chats")
}

model Media {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  key       String   @unique
  url       String
  mimeType  String   @map("mime_type")
  size      Int
  createdAt DateTime @default(now()) @map("created_at")

  messages Message[] @relation("MessageMedia")

  @@index([userId])
  @@map("media")
}

model Message {
  id        String      @id @default(cuid())
  chatId    String      @map("chat_id")
  chat      Chat        @relation(fields: [chatId], references: [id], onDelete: Cascade)
  senderId  String      @map("sender_id")
  sender    User        @relation(fields: [senderId], references: [id], onDelete: Cascade)
  content   String
  type      MessageType @default(TEXT)
  mediaUrl  String?     @map("media_url")
  media     Media[]     @relation("MessageMedia")
  read      Boolean     @default(false)
  createdAt DateTime    @default(now()) @map("created_at")

  @@index([chatId, createdAt])
  @@index([senderId])
  @@map("messages")
}

model AchievementDefinition {
  id           String  @id @default(cuid())
  name         String  @unique
  description  String
  icon         String?
  criteriaType String  @map("criteria_type") // e.g. TOURNAMENT_PARTICIPATION, TOURNAMENT_WIN
  threshold    Int     @default(1) // e.g. 1, 5, 10 for tiered achievements

  userAchievements UserAchievement[]

  @@map("achievement_definitions")
}

model UserAchievement {
  id            String                @id @default(cuid())
  userId        String                @map("user_id")
  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievementId String                @map("achievement_id")
  achievement   AchievementDefinition @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  progress      Int                   @default(0)
  unlockedAt    DateTime?             @map("unlocked_at")
  createdAt     DateTime              @default(now()) @map("created_at")

  featuredOn UserProfile[] @relation("FeaturedAchievements")

  @@unique([userId, achievementId])
  @@index([userId])
  @@map("user_achievements")
}

model Tournament {
  id     String           @id @unique @default(cuid())
  name   String
  sport  Sport            @relation(fields: [sportId], references: [id])
  format TournamentFormat @default(SINGLE_ELIMINATION)
  status TournamentStatus @default(OPEN)

  maxTeams  Int      @map("max_teams")
  startDate DateTime @map("start_date")
  createdAt DateTime @default(now()) @map("created_at")

  createdById    String       @map("created_by_id")
  createdBy      User         @relation("TournamentCreator", fields: [createdById], references: [id])
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id])

  users       User[]                 @relation("TournamentParticipants")
  teams       Team[]                 @relation("TournamentTeams")
  matches     TournamentMatch[]
  invitations TournamentInvitation[]
  sportId     String                 @map("sport_id") @db.Uuid

  @@index([organizationId])
  @@index([createdById])
  @@index([sportId])
  @@map("tournaments")
}

enum TournamentInvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model TournamentInvitation {
  id           String                     @id @default(cuid())
  tournamentId String                     @map("tournament_id")
  tournament   Tournament                 @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  teamId       String                     @map("team_id")
  team         Team                       @relation("TournamentInvitations", fields: [teamId], references: [id], onDelete: Cascade)
  status       TournamentInvitationStatus @default(PENDING)
  createdAt    DateTime                   @default(now()) @map("created_at")
  updatedAt    DateTime                   @updatedAt @map("updated_at")

  @@unique([tournamentId, teamId, status])
  @@index([teamId])
  @@map("tournament_invitations")
}

enum TournamentFormat {
  SINGLE_ELIMINATION
  ROUND_ROBIN
}

enum TournamentStatus {
  OPEN
  CLOSED
  UPCOMING
  INPROGRESS
  COMPLETED
}

enum MatchStatus {
  PENDING
  COMPLETED
  BYE
}

model TournamentMatch {
  id           String     @id @default(cuid())
  tournamentId String     @map("tournament_id")
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  round        Int
  matchNumber  Int        @map("match_number")

  team1Id    String? @map("team1_id")
  team1      Team?   @relation("MatchTeam1", fields: [team1Id], references: [id])
  team2Id    String? @map("team2_id")
  team2      Team?   @relation("MatchTeam2", fields: [team2Id], references: [id])
  team1Score Int?    @map("team1_score")
  team2Score Int?    @map("team2_score")
  winnerId   String? @map("winner_id")
  winner     Team?   @relation("MatchWinner", fields: [winnerId], references: [id])

  status MatchStatus @default(PENDING)

  nextMatchId     String?           @map("next_match_id")
  nextMatch       TournamentMatch?  @relation("BracketProgression", fields: [nextMatchId], references: [id])
  previousMatches TournamentMatch[] @relation("BracketProgression")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([tournamentId, round, matchNumber])
  @@index([tournamentId])
  @@map("tournament_matches")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  content   String
  dismissed Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, dismissed])
  @@map("notifications")
}

model Team {
  id          String @id @default(cuid())
  name        String
  description String @default("")
  captainId   String @map("captain_id")
  captain     User   @relation("TeamCaptain", fields: [captainId], references: [id], onDelete: Cascade)

  sportId String @map("sport_id") @db.Uuid
  sport   Sport  @relation(fields: [sportId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users                 User[]                 @relation("TeamMembers")
  invitations           TeamInvitation[]
  tournaments           Tournament[]           @relation("TournamentTeams")
  tournamentInvitations TournamentInvitation[] @relation("TournamentInvitations")
  matchesAsTeam1        TournamentMatch[]      @relation("MatchTeam1")
  matchesAsTeam2        TournamentMatch[]      @relation("MatchTeam2")
  matchesWon            TournamentMatch[]      @relation("MatchWinner")

  // Team chats (US #44)
  chatsAsTeam1 Chat[] @relation("ChatTeam1")
  chatsAsTeam2 Chat[] @relation("ChatTeam2")

  // Team blocking (US #45)
  blocksInitiated TeamBlock[] @relation("BlockingTeam")
  blocksReceived  TeamBlock[] @relation("BlockedTeam")

  // Meetups (US #46)
  meetupsProposed Meetup[] @relation("MeetupProposer")
  meetupsReceived Meetup[] @relation("MeetupReceiver")

  @@index([captainId])
  @@index([sportId])
  @@map("teams")
}

enum TeamInvitationType {
  INVITE
  REQUEST
}

enum TeamInvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model TeamInvitation {
  id        String               @id @default(cuid())
  teamId    String               @map("team_id")
  team      Team                 @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId    String               @map("user_id")
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      TeamInvitationType
  status    TeamInvitationStatus @default(PENDING)
  createdAt DateTime             @default(now()) @map("created_at")
  updatedAt DateTime             @updatedAt @map("updated_at")

  @@unique([teamId, userId, type, status])
  @@index([userId])
  @@map("team_invitations")
}

