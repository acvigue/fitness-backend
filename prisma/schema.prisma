// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client"
  output     = "../src/generated/prisma"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id // OIDC subject (sub) claim
  email     String?
  name      String?
  username  String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  profile UserProfile?

  memberships      OrganizationMember[]
  submittedReports Report[]             @relation("ReportSubmitter")
  receivedReports  Report[]             @relation("ReportedUser")
  messages         Message[]
  createdChats     Chat[]               @relation("ChatCreator")
  chatMemberships  Chat[]               @relation("ChatMembers")
  teamCaptainships Team[]               @relation("TeamCaptain")
  teamMemberships  Team[]               @relation("TeamMembers")

  sessions    Session[]
  Achievement Achievement[]
  createdTournaments Tournament[] @relation("TournamentCreator")
  tournaments        Tournament[] @relation("TournamentParticipants")

  @@map("users")
}

model Session {
  id     String @id @default(cuid())
  userId String @map("user_id")

  ipAddress String? @map("ip_address")
  userAgent String? @map("user_agent")
  location  String?

  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model UserProfile {
  userId    String   @id @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio       String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  pictures       UserProfilePicture[]
  favoriteSports Sport[]              @relation("UserFavoriteSports")

  @@map("user_profiles")
}

model Sport {
  id   String  @id @default(uuid()) @db.Uuid
  name String  @unique
  icon String?

  profiles    UserProfile[] @relation("UserFavoriteSports")
  tournaments Tournament[]
  teams       Team[]

  @@map("sports")
}

model UserProfilePicture {
  id      String      @id @default(cuid())
  userId  String      @map("user_id")
  profile UserProfile @relation(fields: [userId], references: [userId], onDelete: Cascade)

  url       String
  alt       String?
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("user_profile_pictures")
}

model Organization {
  id        String   @id @default(cuid())
  name      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members     OrganizationMember[]
  tournaments Tournament[]

  @@map("organizations")
}

enum OrganizationRole {
  MEMBER
  STAFF
  ADMIN
}

model OrganizationMember {
  id             String           @id @default(cuid())
  userId         String           @map("user_id")
  organizationId String           @map("organization_id")
  role           OrganizationRole @default(MEMBER)
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@map("organization_members")
}

enum StatusOnReport {
  PENDING
  REVIEWED
  RESOLVED
  DISMISSED
}

model Report {
  id           String         @id @default(cuid())
  reporter     User           @relation("ReportSubmitter", fields: [userId1], references: [id])
  userId1      String
  reportedUser User           @relation("ReportedUser", fields: [userId2], references: [id])
  userId2      String
  reason       String?
  status       StatusOnReport @default(PENDING)
  createdAt    DateTime       @default(now()) @map("created_at")
}

enum ChatType {
  DIRECT
  GROUP
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  FILE
}

model Chat {
  id        String    @id @default(cuid())
  type      ChatType  @default(GROUP)
  name      String?
  creatorId String    @map("creator_id")
  creator   User      @relation("ChatCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  members   User[]    @relation("ChatMembers")
  messages  Message[]
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([creatorId])
  @@map("chats")
}

model Media {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  key       String   @unique
  url       String
  mimeType  String   @map("mime_type")
  size      Int
  createdAt DateTime @default(now()) @map("created_at")

  messages Message[] @relation("MessageMedia")

  @@index([userId])
  @@map("media")
}

model Message {
  id        String      @id @default(cuid())
  chatId    String      @map("chat_id")
  chat      Chat        @relation(fields: [chatId], references: [id], onDelete: Cascade)
  senderId  String      @map("sender_id")
  sender    User        @relation(fields: [senderId], references: [id], onDelete: Cascade)
  content   String
  type      MessageType @default(TEXT)
  mediaUrl  String?     @map("media_url")
  media     Media[]     @relation("MessageMedia")
  read      Boolean     @default(false)
  createdAt DateTime    @default(now()) @map("created_at")

  @@index([chatId, createdAt])
  @@index([senderId])
  @@map("messages")
}

model Achievement {
  id          String   @id @unique @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String
  earnedAt    DateTime @default(now())
}

model Tournament {
  id     String           @id @unique @default(cuid())
  name   String
  sport  Sport            @relation(fields: [sportId], references: [id])
  status TournamentStatus @default(OPEN)

  maxTeams  Int      @map("max_teams")
  startDate DateTime @map("start_date")
  createdAt DateTime @default(now()) @map("created_at")

  createdById    String       @map("created_by_id")
  createdBy      User         @relation("TournamentCreator", fields: [createdById], references: [id])
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id])

  users   User[] @relation("TournamentParticipants")
  sportId String @db.Uuid @map("sport_id")

  @@index([organizationId])
  @@index([createdById])
  @@index([sportId])
  @@map("tournaments")
}

enum TournamentStatus {
  OPEN
  CLOSED
  UPCOMING
  INPROGRESS
  COMPLETED
}

model Team {
  id          String   @id @default(cuid())
  name        String
  description String   @default("")
  captainId   String   @map("captain_id")
  captain User  @relation("TeamCaptain", fields: [captainId], references: [id], onDelete: Cascade)

  sportId     String   @db.Uuid @map("sport_id")
  sport   Sport @relation(fields: [sportId], references: [id])

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users User[] @relation("TeamMembers")

  @@index([captainId])
  @@index([sportId])
  @@map("teams")
}